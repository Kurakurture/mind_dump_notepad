{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mind Dump",
  "version": "0.1.0",
 "identifier": "com.kurakurture.minddumpnotes",
"build": {
  "beforeDevCommand": "",
  "beforeBuildCommand": "",
  "frontendDist": "../web"
},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mind Dump",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
