{
  "name": "mind-dump",
  "version": "1.0.0",
  "description": "Minimal local mind dump notes app for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "sh scripts/build-icon.sh",
    "build": "npm run icon && electron-builder"
  },
  "build": {
    "appId": "com.minddump.app",
    "productName": "Mind Dump",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "files": [
      "web/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12"
  }
}
